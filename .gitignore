# Agent tooling
# Personal, per-machine settings — must not be shared.
.claude/settings.local.json
# Isolated worktree checkouts — each is a full working copy of this repo.
.claude/worktrees/
# Session scratch from the superpowers workflow.
.superpowers/
# Third-party skills installed by `npx skills add`. Restorable from the
# committed skills-lock.json, so they are build output rather than source.
# .claude/skills/<name> is a symlink into .agents/ — ignore both together,
# or teammates get a dangling link. Add a line here for each new locked skill.
.agents/
.claude/skills/supabase
.claude/skills/supabase-postgres-best-practices

# TypeScript
*.tsbuildinfo
next-env.d.ts
